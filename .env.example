# Copie para .env e preencha (valores em Supabase → Settings → API)
# Nunca commite o arquivo .env

VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_ou_publishable

# Segredos de Groq / YouTube / Klipy: configure como secrets da Edge Function `api-proxy`
# (ver supabase/functions/README.md). Não é necessário VITE_* para essas APIs no cliente.
